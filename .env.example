# Database Connection URL (Postgres or SQLite file path)
# Production Example: postgresql://username:password@ep-cool-sun-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
# Local SQLite Example: file:./dev.db
DATABASE_URL="file:./dev.db"

# JWT Secret Key for signing token hashes (use a secure random string in production)
JWT_SECRET="your-super-secret-production-key"

# Port on which the express backend server will listen
PORT=5000

# URL of the frontend client for CORS origin permissions
FRONTEND_URL="http://localhost:5173"
