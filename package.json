{
  "name": "opspilot-root",
  "version": "1.0.0",
  "private": true,
  "description": "OpsPilot — Enterprise SaaS Commercial ERP & Operations Portal",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:server": "npm run dev --prefix backend",
    "dev:client": "npm run dev --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "typecheck:backend": "npx tsc --noEmit --prefix backend",
    "typecheck:frontend": "npx tsc --noEmit --prefix frontend",
    "db:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:seed": "npx ts-node backend/src/prisma/seed.ts",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down"
  }
}
