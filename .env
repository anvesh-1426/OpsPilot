# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opspilot?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Change these to secure random strings in production!
JWT_SECRET=opspilot-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=opspilot-refresh-secret-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
LOG_LEVEL=info
